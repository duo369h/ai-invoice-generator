NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# DeepSeek is optional. Without this key, InvoiceAI uses the local fallback parser.
DEEPSEEK_API_KEY=

# Supabase is optional for local demo mode. Fill these to enable login and cloud invoice history.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production rate limiting. Required in production; local demo falls back to in-memory limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe production skeleton. Required before enabling paid subscriptions.
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Analytics & Verification (For product launch)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_CLARITY_ID=
