NEXT_PUBLIC_SITE_URL=https://www.corvioz.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@corvioz.com
NEXT_PUBLIC_HELLO_EMAIL=hello@corvioz.com
NEXT_PUBLIC_BILLING_EMAIL=billing@corvioz.com

# DeepSeek is optional. Without this key, Corvioz uses the local heuristic parser.
DEEPSEEK_API_KEY=

# Supabase is required for authenticated production persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production rate limiting. Required in production; local development falls back to in-memory limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Paddle Billing ───────────────────────────────────────────────────────────
# Core credentials — required for checkout and webhook verification.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Set to 'sandbox' for testing, 'production' for live payments.
NEXT_PUBLIC_PADDLE_ENV=production

# Pro plan price IDs (from Paddle dashboard → Catalog → Prices)
NEXT_PUBLIC_PADDLE_PRO_PRICE_ID=
NEXT_PUBLIC_PADDLE_PRO_YEARLY_PRICE_ID=

# Growth plan price IDs
NEXT_PUBLIC_PADDLE_GROWTH_PRICE_ID=
NEXT_PUBLIC_PADDLE_GROWTH_YEARLY_PRICE_ID=

# Studio / Agency plan price IDs
NEXT_PUBLIC_PADDLE_AGENCY_PRICE_ID=
NEXT_PUBLIC_PADDLE_AGENCY_YEARLY_PRICE_ID=
# Aliases used by the webhook resolver (same values as above if you use a single "studio" product)
NEXT_PUBLIC_PADDLE_STUDIO_PRICE_ID=
NEXT_PUBLIC_PADDLE_STUDIO_YEARLY_PRICE_ID=

# Analytics & Verification
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_CLARITY_ID=

# Future email provider placeholder. Do not enable until Resend is integrated.
RESEND_API_KEY=
RESEND_FROM_SUPPORT=support@corvioz.com
RESEND_FROM_BILLING=billing@corvioz.com
