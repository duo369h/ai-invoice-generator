NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# DeepSeek is optional. Without this key, InvoiceAI uses the local fallback parser.
DEEPSEEK_API_KEY=

# Supabase is optional for local demo mode. Fill these to enable login and cloud invoice history.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
